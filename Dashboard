import React, { useState, useEffect } from "react";
import { User, Transaction, ExchangeRate } from "@/entities/all";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Link } from "react-router-dom";
import { createPageUrl } from "@/utils";
import { 
  Send, 
  Receipt, 
  Wallet, 
  TrendingUp, 
  Globe,
  ArrowUpRight,
  ArrowDownLeft,
  Plus,
  Eye,
  EyeOff
} from "lucide-react";
import { motion } from "framer-motion";
import { format } from "date-fns";

import WalletCard from "../components/dashboard/WalletCard";
import QuickActions from "../components/dashboard/QuickActions";
import RecentTransactions from "../components/dashboard/RecentTransactions";
import CurrencyExchange from "../components/dashboard/CurrencyExchange";

export default function Dashboard() {
  const [user, setUser] = useState(null);
  const [transactions, setTransactions] = useState([]);
  const [exchangeRates, setExchangeRates] = useState([]);
  const [isLoading, setIsLoading] = useState(true);
  const [showBalance, setShowBalance] = useState(true);
  const [isDarkMode, setIsDarkMode] = useState(false);

  useEffect(() => {
    loadDashboardData();
    // Check for dark mode
    const checkDarkMode = () => {
      setIsDarkMode(document.documentElement.classList.contains('dark'));
    };
    checkDarkMode();
    
    // Listen for theme changes
    const observer = new MutationObserver(checkDarkMode);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    
    return () => observer.disconnect();
  }, []);

  const loadDashboardData = async () => {
    setIsLoading(true);
    try {
      const currentUser = await User.me();
      setUser(currentUser);

      const userTransactions = await Transaction.filter(
        { sender_id: currentUser.id },
        '-created_date',
        10
      );
      setTransactions(userTransactions);

      const rates = await ExchangeRate.list('-updated_date', 10);
      setExchangeRates(rates);
    } catch (error) {
      console.error("Error loading dashboard data:", error);
    }
    setIsLoading(false);
  };

  const getGreeting = () => {
    const hour = new Date().getHours();
    if (hour < 12) return "Good morning";
    if (hour < 17) return "Good afternoon";
    return "Good evening";
  };

  const getQuickStats = () => {
    const thisMonth = transactions.filter(t => {
      const transactionDate = new Date(t.created_date);
      const now = new Date();
      return transactionDate.getMonth() === now.getMonth() && 
             transactionDate.getFullYear() === now.getFullYear();
    });

    return {
      totalSent: thisMonth.reduce((sum, t) => sum + (t.amount_sent || 0), 0),
      transactionCount: thisMonth.length,
      avgAmount: thisMonth.length > 0 ? 
        thisMonth.reduce((sum, t) => sum + (t.amount_sent || 0), 0) / thisMonth.length : 0
    };
  };

  const stats = getQuickStats();

  return (
    <div className={`min-h-screen p-4 md:p-8 transition-colors duration-300 ${
      isDarkMode 
        ? 'bg-gradient-to-br from-gray-900 via-gray-800 to-green-900' 
        : 'bg-gradient-to-br from-gray-50 via-white to-green-50'
    }`}>
      <div className="max-w-7xl mx-auto space-y-8">
        {/* Welcome Header */}
        <motion.div 
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4"
        >
          <div>
            <h1 className={`text-3xl md:text-4xl font-bold mb-2 transition-colors duration-300 ${
              isDarkMode ? 'text-gray-100' : 'text-gray-900'
            }`}>
              {getGreeting()}, {user?.full_name?.split(' ')[0] || 'User'}! 👋
            </h1>
            <p className={`text-lg transition-colors duration-300 ${
              isDarkMode ? 'text-gray-300' : 'text-gray-600'
            }`}>
              Ready to send money to your loved ones?
            </p>
          </div>
          <div className="flex gap-3">
            <Link to={createPageUrl("SendMoney")}>
              <Button className="strattopay-gradient hover:opacity-90 text-white px-6 py-3 rounded-xl">
                <Send className="w-5 h-5 mr-2" />
                Send Money
              </Button>
            </Link>
          </div>
        </motion.div>

        {/* Wallet & Quick Stats */}
        <div className="grid lg:grid-cols-3 gap-6">
          <div className="lg:col-span-2">
            <WalletCard 
              user={user}
              isLoading={isLoading}
              showBalance={showBalance}
              setShowBalance={setShowBalance}
              isDarkMode={isDarkMode}
            />
          </div>
          
          <div className="space-y-4">
            <motion.div
              initial={{ opacity: 0, x: 20 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ delay: 0.2 }}
            >
              <Card className={`strattopay-card hover-lift transition-colors duration-300`}>
                <CardHeader className="pb-3">
                  <CardTitle className={`text-lg font-semibold transition-colors duration-300 ${
                    isDarkMode ? 'text-gray-100' : 'text-gray-900'
                  }`}>This Month</CardTitle>
                </CardHeader>
                <CardContent className="space-y-4">
                  <div className="flex justify-between items-center">
                    <span className={`transition-colors duration-300 ${
                      isDarkMode ? 'text-gray-300' : 'text-gray-600'
                    }`}>Total Sent</span>
                    <span className={`font-bold text-xl transition-colors duration-300 ${
                      isDarkMode ? 'text-green-400' : 'text-green-600'
                    }`}>
                      ${stats.totalSent.toFixed(2)}
                    </span>
                  </div>
                  <div className="flex justify-between items-center">
                    <span className={`transition-colors duration-300 ${
                      isDarkMode ? 'text-gray-300' : 'text-gray-600'
                    }`}>Transactions</span>
                    <span className={`font-semibold transition-colors duration-300 ${
                      isDarkMode ? 'text-gray-200' : 'text-gray-700'
                    }`}>{stats.transactionCount}</span>
                  </div>
                  <div className="flex justify-between items-center">
                    <span className={`transition-colors duration-300 ${
                      isDarkMode ? 'text-gray-300' : 'text-gray-600'
                    }`}>Average</span>
                    <span className={`font-semibold transition-colors duration-300 ${
                      isDarkMode ? 'text-gray-200' : 'text-gray-700'
                    }`}>${stats.avgAmount.toFixed(2)}</span>
                  </div>
                </CardContent>
              </Card>
            </motion.div>

            <QuickActions isDarkMode={isDarkMode} />
          </div>
        </div>

        {/* Main Content Grid */}
        <div className="grid lg:grid-cols-3 gap-6">
          <div className="lg:col-span-2">
            <RecentTransactions 
              transactions={transactions}
              isLoading={isLoading}
              isDarkMode={isDarkMode}
            />
          </div>
          
          <div>
            <CurrencyExchange 
              exchangeRates={exchangeRates}
              isLoading={isLoading}
              isDarkMode={isDarkMode}
            />
          </div>
        </div>
      </div>
    </div>
  );
